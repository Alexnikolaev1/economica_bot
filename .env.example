# Telegram
TELEGRAM_BOT_TOKEN=

# AI
GEMINI_API_KEY=
GROQ_API_KEY=

# Railway / production (webhook)
# Railway задаёт RAILWAY_STATIC_URL автоматически — бот переключится на webhook
# Или укажите вручную:
# WEBHOOK_URL=https://your-app.up.railway.app
# PORT=8080

# База данных (на Railway смонтируйте volume в /data)
DB_PATH=local.db

# Google Sheets — JSON service account одной строкой (см. Google Cloud Console)
# GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account",...}
# Пользователи привязывают свою таблицу через /sheets link
