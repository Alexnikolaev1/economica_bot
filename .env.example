# Telegram
TELEGRAM_BOT_TOKEN=

# Доступ: только перечисленные Telegram user ID (через запятую)
# Узнать свой ID: напишите боту @userinfobot или попробуйте /start без доступа
# ALLOWED_USER_IDS=123456789,987654321

# AI
GEMINI_API_KEY=
GROQ_API_KEY=

# Railway / production
# Включите Public Networking у сервиса — Railway задаст RAILWAY_PUBLIC_DOMAIN
# Или укажите вручную:
# WEBHOOK_URL=https://your-app.up.railway.app
# PORT задаётся Railway автоматически

# База данных (на Railway смонтируйте volume в /data)
DB_PATH=local.db

# Google Sheets — JSON service account одной строкой (см. Google Cloud Console)
# GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account",...}
# Пользователи привязывают свою таблицу через /sheets link
